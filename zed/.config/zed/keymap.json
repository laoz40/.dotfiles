[
  {
    "context": "Editor && vim_mode == normal && !VimWaiting",
    "bindings": {
      "ctrl-j": "terminal_panel::Toggle",
      "space a": "agent::Toggle",
      "space e": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "ProjectPanel && vim_mode == normal && !VimWaiting",
    "bindings": {
      "space a": "agent::Toggle",
      "space e": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-6": "pane::AlternateFile",
    },
  },
]
