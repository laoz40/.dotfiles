// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "zed",
  },
  "title_bar": {
    "show_user_menu": false,
  },
  "tab_bar": {
    "show": false,
  },
  "preview_tabs": {
    "enabled": true,
  },
  "toolbar": {
    "selections_menu": false,
    "breadcrumbs": false,
    "quick_actions": false,
    "agent_review": false,
    "code_actions": false,
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "pi-acp": {
      "type": "registry",
    },
  },
  "context_servers": {},
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "scrollbar": {
    "git_diff": false,
  },
  "project_panel": {
    "dock": "left",
  },
  "tabs": {
    "show_diagnostics": "off",
    "file_icons": false,
    "git_status": true,
  },
  "status_bar": {
    "show_active_file": false,
  },
  "vim_mode": true,
  "proxy": "",
  "tab_size": 2,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "cursor_shape": "block",
  "agent_buffer_font_size": 12.0,
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "close_window",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "blue-gold",
  },
  "theme_overrides": {
    "blue-gold": {
      "background.appearance": "blurred",
      "background": "#0e2133f2",
      "editor.background": "#0e2133f2",
      "editor.gutter.background": "#0e2133f2",
      "tab_bar.background": "#0e2133f2",
      "status_bar.background": "#0e2133f2",
      "title_bar.background": "#0e2133f2",
      "panel.background": "#0e2133f2"
    }
  }
}
